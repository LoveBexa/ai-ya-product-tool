# AI provider: ollama | openai | google | gateway | openrouter | deepseek
# Defaults to ollama in development, gateway in production.
# deepseek = OpenRouter with deepseek/deepseek-chat (cheap, good for dev).
AI_PROVIDER=ollama

# --- Supabase (optional — projects persist when set) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
#
# Optional demo data: run scripts/seed-demo-project.sql then open
# /projects/00000000-0000-4000-a800-000000000001
# Install: https://ollama.com — then run `ollama pull qwen2.5:14b`
OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:14b

# --- OpenAI (direct API key, billed by OpenAI) ---
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# --- Google Gemini (direct API key from https://aistudio.google.com/apikey) ---
# AI_PROVIDER=google
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-2.5-flash

# --- OpenRouter (DeepSeek, GPT-4o, etc. via one API key) ---
# Get a key at https://openrouter.ai/keys
# AI_PROVIDER=deepseek
# OPENROUTER_API_KEY=
# OPENROUTER_MODEL=deepseek/deepseek-chat
# OPENROUTER_SITE_URL=http://localhost:3000
# OPENROUTER_APP_NAME=AIYA

# --- Vercel AI Gateway (uses Vercel credits on deploy) ---
# AI_GATEWAY_MODEL=openai/gpt-5.4-mini
# AI_GATEWAY_API_KEY=

# --- Supabase (optional — projects persist when set) ---
# NEXT_PUBLIC_SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
