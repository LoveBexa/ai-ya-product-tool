# --- AI provider (server-only — not user-selectable in the UI) ---
# DeepSeek: pay-as-you-go after signup credits. "Insufficient Balance" = top up at platform.deepseek.com
# AI_PROVIDER=deepseek
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat

# Google Gemini: free tier available (gemini-2.0-flash has separate quota from 2.5)
# AI_PROVIDER=google
# GOOGLE_GENERATIVE_AI_API_KEY=
# GOOGLE_MODEL=gemini-2.0-flash

# Billing tier — defaults to free (1 project, 1 blueprint). Set to paid for unlimited.
# AIYA_BILLING_TIER=free

# --- Supabase (optional — projects persist when set) ---
# NEXT_PUBLIC_SUPABASE_URL=
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
#
# Auth (when NEXT_PUBLIC_SUPABASE_ANON_KEY is set):
# 1. Supabase Dashboard → Authentication → Providers → enable Google + Email (magic link)
# 2. Authentication → URL Configuration → add redirect: https://your-domain/auth/callback
#    (local dev: http://localhost:3000/auth/callback)
#
# Optional demo data: run scripts/seed-demo-project.sql then open
# /projects/00000000-0000-4000-a800-000000000001
